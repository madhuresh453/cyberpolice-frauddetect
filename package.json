{
  "name": "cybershield-ai",
  "version": "0.1.0",
  "private": true,
  "description": "National cyber fraud detection and prevention platform scaffold.",
  "type": "module",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "node --watch backend/server.js",
    "seed": "node scripts/seeds/seed-demo-data.js",
    "db:verify": "node scripts/verify-mongodb.js",
    "phase1:verify": "powershell -ExecutionPolicy Bypass -File scripts/verify-phase1.ps1",
    "phase2:verify": "node scripts/verify-mongodb.js",
    "test:security": "node tests/security/security-validation.js",
    "test:load:10k": "TOTAL_USERS=10000 CONCURRENCY=1000 node tests/load-testing/run-load-tests.js",
    "test:load:50k": "TOTAL_USERS=50000 CONCURRENCY=5000 node tests/load-testing/run-load-tests.js",
    "test:load:100k": "TOTAL_USERS=100000 CONCURRENCY=10000 node tests/load-testing/run-load-tests.js",
    "test:load:full": "node tests/load-testing/run-load-tests.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "google-auth-library": "^10.7.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "libphonenumber-js": "^1.13.6",
    "mongoose": "^8.9.5",
    "multer": "^2.1.1",
    "neo4j-driver": "^6.1.0",
    "redis": "^6.0.0",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@11.6.4"
}
